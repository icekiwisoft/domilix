# Docker images
FRONTEND_IMAGE=ghcr.io/your-org/domilix-frontend:latest
BACKEND_IMAGE=ghcr.io/your-org/domilix-backend:latest

# Domains routed by Traefik
FRONTEND_HOST=domilix.com
DEV_FRONTEND_HOST=new.domilix.com
BACKEND_HOST=api.domilix.com

# External Traefik setup
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=le

# MySQL
DB_ROOT_PASSWORD=change-me
DB_DATABASE=domilix
DB_USERNAME=domilix
DB_PASSWORD=change-me
DATABASE_URL=mysql://domilix:change-me@db:3306/domilix

# Nest backend env
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
MAPBOX_ACCESS_TOKEN=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=eu-west-2
WASABI_BUCKET=
WASABI_ENDPOINT=https://s3.eu-west-2.wasabisys.com
WASABI_PUBLIC_BASE_URL=
